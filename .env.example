# Database Configuration
# Connects to Vercel Postgres or Neon PostgreSQL in production.
# Leave blank in development to auto-fallback to local SQLite.
DATABASE_URL="postgres://username:password@hostname:5432/databasename?sslmode=require"
POSTGRES_URL="postgres://username:password@hostname:5432/databasename?sslmode=require"

# Authentication Secret
# Secret key used for signing JWT session cookies. Change this to a secure random string in production.
JWT_SECRET="litera-cms-secret-change-in-prod-2026"

# Vercel Blob Storage Token
# Required in production to store uploaded materials and media assets.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
